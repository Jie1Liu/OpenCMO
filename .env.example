# Shared
APP_ENV=development

# Backend
# Optional. If omitted, AIMO uses /tmp/aimo.db for the self-contained demo.
DATABASE_URL=postgresql+psycopg://aimo:aimo@localhost:5432/aimo
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://aimo-gold.vercel.app
AWS_REGION=us-east-1
SQS_SEARCH_QUEUE_URL=
SQS_AI_QUEUE_URL=
SQS_INSIGHT_QUEUE_URL=
SQS_OUTREACH_QUEUE_URL=
SECRETS_MANAGER_PREFIX=aimo/
BEDROCK_MODEL_ID=
OPENAI_API_KEY=
# Any OpenAI-compatible provider uses the four LLM_* variables below.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.5
LLM_API_STYLE=chat_completions
# DeepSeek example:
# LLM_API_KEY=your-deepseek-key
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-flash
# LLM_API_STYLE=chat_completions
# Qwen / Alibaba Cloud Model Studio example:
# LLM_API_KEY=your-dashscope-key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# LLM_API_STYLE=chat_completions
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
BLUESKY_SERVICE_URL=https://bsky.social
BLUESKY_PUBLIC_API_URL=https://api.bsky.app
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
JWT_SECRET=change-me-in-production

# Frontend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
